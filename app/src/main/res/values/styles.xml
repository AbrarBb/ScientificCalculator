<resources>

    <!-- LCM(5,6)=30: 6 keys × weight 5 = 30; 5 keys × weight 6 = 30 → columns line up -->
    <style name="KeyRowGrid">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:weightSum">30</item>
    </style>

    <!-- Fills remaining screen height when placed in a vertical parent with weights -->
    <style name="KeyRowGridWeighted">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:weightSum">30</item>
        <item name="android:baselineAligned">false</item>
    </style>

    <style name="KeyBaseGrid" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_margin">@dimen/key_margin</item>
        <item name="android:minHeight">@dimen/key_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="cornerRadius">@dimen/key_corner</item>
        <item name="android:elevation">@dimen/key_elevation</item>
    </style>

    <style name="KeyWhite" parent="KeyBaseGrid">
        <item name="android:backgroundTint">@color/key_white</item>
        <item name="android:textColor">@color/lcd_text</item>
        <item name="android:textSize">@dimen/key_text_sci</item>
        <item name="strokeColor">#CCCCCC</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="KeyWhiteLarge" parent="KeyWhite">
        <item name="android:textSize">@dimen/key_text_num</item>
    </style>

    <style name="KeyDark" parent="KeyBaseGrid">
        <item name="android:backgroundTint">@color/key_dark</item>
        <item name="android:textColor">@color/key_dark_text</item>
        <item name="android:textSize">@dimen/key_text_sci</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="KeyDarkLarge" parent="KeyDark">
        <item name="android:textSize">@dimen/key_text_num</item>
    </style>
</resources>
